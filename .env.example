# =============================
# Corque base configuration
# =============================
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
SMTP_SERVER=smtp.example.com
IMAP_SERVER=imap.example.com
SENDER_NAME=Corque
USER_NAME=Corque
REGION=

# Required for default hosted model path in this repo
DEDALUS_API_KEY=

# Optional (needed only for web search/news tools)
TAVILY_API_KEY=

# =============================
# runShellCommand hardening
# =============================
# Root folder where shell commands are allowed to execute.
# Leave empty to use repository root.
SHELL_SANDBOX_ROOT=

# Append-only audit log for shell tool execution decisions
SHELL_AUDIT_LOG_PATH=

# Enforce command allowlist and sandbox
SHELL_REQUIRE_ALLOWLIST=true
SHELL_ENFORCE_SANDBOX=true

# Comma-separated list (case-insensitive)
SHELL_ALLOWED_COMMANDS=dir,ls,pwd,cd,type,cat,echo,python,py,node,npm,git,where,whoami,hostname,Get-ChildItem,Get-Location

# Comma-separated patterns blocked before execution
SHELL_DENIED_PATTERNS= rm , rmdir , del , format , shutdown , restart-computer , net user , net localgroup , curl http,wget http, powershell -enc, certutil -decode,../,..\,&&,||,>
